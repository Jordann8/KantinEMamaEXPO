<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900" prefWidth="1280" style="-fx-background-color: #F9FAFB;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="siptek.kantinemama.controller.pegawai.KelolaMenuController">
    <children>
        <VBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <children>
                <HBox alignment="CENTER_LEFT" maxHeight="70" minHeight="70" prefHeight="70" style="-fx-background-color: #F9FAFB; -fx-padding: 0 32 0 32;">
                    <children>
                        <Label style="-fx-text-fill: #0F2044; -fx-font-size: 20; -fx-font-weight: bold;" text="Kantin E Mama" />
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="32">
                            <children>
                                <Button fx:id="navAntrian" onAction="#onNavAntrian" style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-font-size: 16; -fx-border-color: transparent; -fx-cursor: hand;" text="Antrian Pesanan" />
                                <Button fx:id="navKelolaMenu" onAction="#onNavKelolaMenu" style="-fx-background-color: transparent; -fx-text-fill: #1565C0; -fx-font-size: 16; -fx-font-weight: bold; -fx-border-color: transparent transparent #1565C0 transparent; -fx-border-width: 0 0 2 0; -fx-cursor: hand;" text="Kelola Menu" />
                            </children>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="navKeluar" onAction="#onNavKeluar" prefHeight="40" style="-fx-background-color: #EF4444; -fx-text-fill: #FFFFFF; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: transparent; -fx-cursor: hand;" text="⏻  KELUAR" />
                    </children>
                </HBox>
                <Region maxHeight="1" minHeight="1" prefHeight="1" style="-fx-background-color: #E5E7EB;" />
                <ScrollPane fitToWidth="true" style="-fx-background-color: #F9FAFB; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="18" style="-fx-padding: 24 32 32 32;">
                            <children>
                                <HBox spacing="18">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" prefWidth="290" spacing="14" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 16;" HBox.hgrow="ALWAYS">
                                            <children>
                                                <VBox>
                                                    <children>
                                                        <Label style="-fx-text-fill: #6B7280; -fx-font-size: 12;" text="Total Katalog Menu" />
                                                        <HBox alignment="BASELINE_LEFT" spacing="4">
                                                            <children>
                                                                <Label fx:id="lblTotalKatalog" style="-fx-text-fill: #111827; -fx-font-size: 22; -fx-font-weight: bold;" text="42" />
                                                                <Label style="-fx-text-fill: #6B7280; -fx-font-size: 12;" text="Barang" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" prefWidth="290" spacing="14" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 16;" HBox.hgrow="ALWAYS">
                                            <children>
                                                <StackPane maxHeight="42" maxWidth="42" style="-fx-min-width: 42; -fx-min-height: 42; -fx-max-width: 42; -fx-max-height: 42; -fx-background-color: #1565C0; -fx-background-radius: 8;">
                                                    <children>
                                                        <Label style="-fx-text-fill: #FFFFFF; -fx-font-size: 16;" text="✓" />
                                                    </children>
                                                </StackPane>
                                                <VBox>
                                                    <children>
                                                        <Label style="-fx-text-fill: #6B7280; -fx-font-size: 12;" text="Aktif di Aplikasi" />
                                                        <HBox alignment="BASELINE_LEFT" spacing="4">
                                                            <children>
                                                                <Label fx:id="lblAktifAplikasi" style="-fx-text-fill: #111827; -fx-font-size: 22; -fx-font-weight: bold;" text="38" />
                                                                <Label style="-fx-text-fill: #6B7280; -fx-font-size: 12;" text="Barang" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" prefWidth="290" spacing="14" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 16;" HBox.hgrow="ALWAYS">
                                            <children>
                                                <StackPane maxHeight="42" maxWidth="42" style="-fx-min-width: 42; -fx-min-height: 42; -fx-max-width: 42; -fx-max-height: 42; -fx-background-color: #EF4444; -fx-background-radius: 8;">
                                                    <children>
                                                        <Label style="-fx-text-fill: #FFFFFF; -fx-font-size: 16;" text="⛔" />
                                                    </children>
                                                </StackPane>
                                                <VBox>
                                                    <children>
                                                        <Label style="-fx-text-fill: #6B7280; -fx-font-size: 12;" text="Menu Kosong/Non-Aktif" wrapText="true" />
                                                        <HBox alignment="BASELINE_LEFT" spacing="4">
                                                            <children>
                                                                <Label fx:id="lblMenuNonAktif" style="-fx-text-fill: #111827; -fx-font-size: 22; -fx-font-weight: bold;" text="4" />
                                                                <Label style="-fx-text-fill: #6B7280; -fx-font-size: 12;" text="Barang" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #E5E7EB; -fx-background-radius: 8; -fx-padding: 8;">
                                    <children>
                                        <Button fx:id="filterSemua" onAction="#onFilterSemua" prefHeight="34" style="-fx-background-color: #0F2044; -fx-text-fill: #FFFFFF; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-color: transparent; -fx-cursor: hand;" text="Semua" />
                                        <Button fx:id="filterMakanan" onAction="#onFilterMakanan" prefHeight="34" style="-fx-background-color: #FFFFFF; -fx-text-fill: #374151; -fx-font-size: 12; -fx-background-radius: 6; -fx-border-color: transparent; -fx-cursor: hand;" text="Makanan" />
                                        <Button fx:id="filterMinuman" onAction="#onFilterMinuman" prefHeight="34" style="-fx-background-color: #FFFFFF; -fx-text-fill: #374151; -fx-font-size: 12; -fx-background-radius: 6; -fx-border-color: transparent; -fx-cursor: hand;" text="Minuman" />
                                        <Button fx:id="filterCamilan" onAction="#onFilterCamilan" prefHeight="34" style="-fx-background-color: #FFFFFF; -fx-text-fill: #374151; -fx-font-size: 12; -fx-background-radius: 6; -fx-border-color: transparent; -fx-cursor: hand;" text="Camilan" />
                                        <Region HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                                <FlowPane fx:id="menuGrid" hgap="18" vgap="18" />
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</AnchorPane>
