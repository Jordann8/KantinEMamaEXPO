<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="623" prefWidth="748" style="-fx-background-color: #F9FAFB;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="siptek.kantinemama.controller.pegawai.EditMenuController">
    <children>
        <VBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <children>
                <HBox alignment="CENTER_LEFT" style="-fx-background-color: #0F2044; -fx-padding: 20 24 20 24;">
                    <children>
                        <Label style="-fx-text-fill: #FFFFFF; -fx-font-size: 20; -fx-font-weight: bold;" text="Edit Menu" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnTutupEdit" onAction="#onTutupEdit" prefHeight="40.0" prefWidth="40.0" style="-fx-background-color: transparent; -fx-text-fill: #FFFFFF; -fx-font-size: 16; -fx-border-color: transparent; -fx-cursor: hand;" text="✕">
                     <font>
                        <Font size="30.0" />
                     </font></Button>
                    </children>
                </HBox>
                <HBox spacing="24" style="-fx-padding: 24;">
                    <children>
                        <VBox prefWidth="200" spacing="8">
                            <children>
                                <Label style="-fx-text-fill: #374151; -fx-font-size: 11; -fx-font-weight: bold;" text="FOTO PRODUK" />
                                <StackPane fx:id="fotoUploadBoxEdit" onMouseClicked="#onPilihFotoEdit" prefHeight="190" prefWidth="190" style="-fx-background-color: #E5E7EB; -fx-background-radius: 8; -fx-cursor: hand;">
                                    <children>
                                        <ImageView fx:id="imgPreviewEdit" fitHeight="190" fitWidth="190" preserveRatio="false" />
                                    </children>
                                </StackPane>
                                <Label style="-fx-text-fill: #9CA3AF; -fx-font-size: 11;" text="Klik untuk ubah foto" />
                            </children>
                        </VBox>
                        <VBox spacing="14" HBox.hgrow="ALWAYS">
                            <children>
                                <VBox spacing="6">
                                    <children>
                                        <Label style="-fx-text-fill: #374151; -fx-font-size: 11; -fx-font-weight: bold;" text="NAMA MENU" />
                                        <TextField fx:id="txtNamaMenuEdit" prefHeight="40" style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13;" />
                                    </children>
                                </VBox>
                                <HBox spacing="14">
                                    <children>
                                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-text-fill: #374151; -fx-font-size: 11; -fx-font-weight: bold;" text="KATEGORI" />
                                                <ComboBox fx:id="cmbKategoriEdit" maxWidth="1.7976931348623157E308" prefHeight="40" style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13;">
                                                    <items>
                                                        <FXCollections fx:factory="observableArrayList">
                                                            <String fx:value="Makanan" />
                                                            <String fx:value="Minuman" />
                                                            <String fx:value="Camilan" />
                                                        </FXCollections>
                                                    </items>
                                                </ComboBox>
                                            </children>
                                        </VBox>
                                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-text-fill: #374151; -fx-font-size: 11; -fx-font-weight: bold;" text="HARGA (RP)" />
                                                <TextField fx:id="txtHargaEdit" prefHeight="40" style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-text-fill: #374151; -fx-font-size: 11; -fx-font-weight: bold;" text="STOK" />
                                                <TextField fx:id="txtStokEdit" prefHeight="40" style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <VBox spacing="6">
                                    <children>
                                        <Label style="-fx-text-fill: #374151; -fx-font-size: 11; -fx-font-weight: bold;" text="DESKRIPSI (OPSIONAL)" />
                                        <TextArea fx:id="txtDeskripsiEdit" prefHeight="60" style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13;" wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <Region VBox.vgrow="ALWAYS" />
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 8 24 20 24;">
                    <children>
                        <VBox>
                            <children>
                                <Label style="-fx-text-fill: #111827; -fx-font-size: 13; -fx-font-weight: bold;" text="STATUS" />
                                <Label style="-fx-text-fill: #9CA3AF; -fx-font-size: 11;" text="Aktif" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <ToggleButton fx:id="toggleStatusEdit" prefHeight="26" prefWidth="46" selected="true" style="-fx-background-color: #1565C0; -fx-background-radius: 13; -fx-border-color: transparent; -fx-cursor: hand;" text="" />
                    </children>
                </HBox>
                <Region maxHeight="1" minHeight="1" prefHeight="1" style="-fx-background-color: #E5E7EB;" />
                <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 18 24 18 24;">
                    <children>
                        <Button fx:id="btnBatalEdit" onAction="#onBatalEdit" prefHeight="42" prefWidth="110" style="-fx-background-color: #FFFFFF; -fx-text-fill: #374151; -fx-font-size: 13; -fx-font-weight: bold; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="BATAL" />
                        <Button fx:id="btnSimpanEdit" onAction="#onSimpanEdit" prefHeight="42" prefWidth="110" style="-fx-background-color: #0F2044; -fx-text-fill: #FFFFFF; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: transparent; -fx-cursor: hand;" text="SIMPAN" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
