<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<AnchorPane prefWidth="524" prefHeight="466" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="siptek.kantinemama.controller.pegawai.HapusMenuController">
    <children>
        <VBox alignment="CENTER" spacing="14" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" style="-fx-padding: 36;">
            <children>
                <StackPane maxWidth="64" maxHeight="64" style="-fx-min-width: 64; -fx-min-height: 64; -fx-max-width: 64; -fx-max-height: 64; -fx-background-color: #FFEBEE; -fx-background-radius: 16;">
                    <children>
                        <Label text="⚠" style="-fx-text-fill: #EF4444; -fx-font-size: 26;" />
                    </children>
                </StackPane>
                <Label text="Hapus Menu?" style="-fx-text-fill: #0F2044; -fx-font-size: 20; -fx-font-weight: bold;" />
                <Label fx:id="lblKonfirmasiHapus" text="Apakah Anda yakin ingin menghapus &quot;Es Teh Manis&quot; dari katalog?" wrapText="true" textAlignment="CENTER" style="-fx-text-fill: #374151; -fx-font-size: 14;" />
                <Label text="Data yang dihapus tidak dapat dikembalikan." wrapText="true" textAlignment="CENTER" maxWidth="1.7976931348623157E308" style="-fx-background-color: #F3F4F6; -fx-text-fill: #6B7280; -fx-font-size: 12; -fx-padding: 10; -fx-background-radius: 6;" />
                <HBox alignment="CENTER" spacing="12">
                    <children>
                        <Button fx:id="btnBatalHapus" text="Batal" onAction="#onBatalHapus" prefWidth="160" prefHeight="44" style="-fx-background-color: #FFFFFF; -fx-text-fill: #374151; -fx-font-size: 13; -fx-font-weight: bold; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" />
                        <Button fx:id="btnYaHapusData" text="Ya, Hapus Data" onAction="#onYaHapusData" prefWidth="160" prefHeight="44" style="-fx-background-color: #EF4444; -fx-text-fill: #FFFFFF; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: transparent; -fx-cursor: hand;" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
