<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<AnchorPane prefWidth="1024" prefHeight="520" style="-fx-background-color: #F9FAFB;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="siptek.kantinemama.controller.pelanggan.PembayaranTunaiController">
    <children>
        <HBox alignment="CENTER" spacing="60" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
            <children>
                <VBox spacing="16" prefWidth="380">
                    <children>
                        <Label text="Pembayaran Tunai" style="-fx-text-fill: #111827; -fx-font-size: 24; -fx-font-weight: bold;" />
                        <Label text="Silakan tunjukkan struk ini atau sebutkan Order ID #ORD-88219 kepada Kasir untuk melakukan pembayaran tunai." wrapText="true" style="-fx-text-fill: #374151; -fx-font-size: 14;" />
                        <HBox spacing="12">
                            <children>
                                <Button fx:id="btnBatal" text="Batal" onAction="#onBatal" prefWidth="120" prefHeight="42" style="-fx-background-color: #FFFFFF; -fx-text-fill: #374151; -fx-font-size: 13; -fx-font-weight: bold; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" />
                                <Button fx:id="btnKembaliKatalog" text="Kembali ke Katalog" onAction="#onKembaliKatalog" prefWidth="180" prefHeight="42" style="-fx-background-color: #E5E7EB; -fx-text-fill: #374151; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-color: transparent; -fx-cursor: hand;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
                <VBox alignment="CENTER" spacing="6" prefWidth="340" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20;">
                    <children>
                        <Label text="Kantin E Mama" style="-fx-text-fill: #0F2044; -fx-font-size: 16; -fx-font-weight: bold;" />
                        <Label text="TRANS ID: #ORD-88219" style="-fx-text-fill: #6B7280; -fx-font-size: 10;" />
                        <Label text="14 Juli 2026 - 12:45" style="-fx-text-fill: #6B7280; -fx-font-size: 10;" />
                        <Region prefHeight="10" />
                        <Region prefWidth="290" prefHeight="1" minHeight="1" maxHeight="1" style="-fx-background-color: #D1D5DB;" />
                        <HBox prefWidth="290">
                            <children>
                                <Label text="2x Sate Ayam Madura" style="-fx-text-fill: #111827; -fx-font-size: 12;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="60.000" style="-fx-text-fill: #111827; -fx-font-size: 12;" />
                            </children>
                        </HBox>
                        <HBox prefWidth="290">
                            <children>
                                <Label text="2x Es Teh Manis" style="-fx-text-fill: #111827; -fx-font-size: 12;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="8.000" style="-fx-text-fill: #111827; -fx-font-size: 12;" />
                            </children>
                        </HBox>
                        <Region prefWidth="290" prefHeight="1" minHeight="1" maxHeight="1" style="-fx-background-color: #D1D5DB;" />
                        <HBox prefWidth="290">
                            <children>
                                <Label text="Subtotal" style="-fx-text-fill: #374151; -fx-font-size: 12;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="68.000" style="-fx-text-fill: #374151; -fx-font-size: 12;" />
                            </children>
                        </HBox>
                        <HBox prefWidth="290">
                            <children>
                                <Label text="Tax (10%)" style="-fx-text-fill: #374151; -fx-font-size: 12;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="6.800" style="-fx-text-fill: #374151; -fx-font-size: 12;" />
                            </children>
                        </HBox>
                        <HBox prefWidth="290" alignment="CENTER_LEFT">
                            <children>
                                <Label text="TOTAL" style="-fx-text-fill: #111827; -fx-font-size: 15; -fx-font-weight: bold;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="lblTotal" text="74.800" style="-fx-text-fill: #111827; -fx-font-size: 17; -fx-font-weight: bold;" />
                            </children>
                        </HBox>
                        <Label text="BELUM DIBAYAR" rotate="-20" style="-fx-text-fill: #FFEBEE; -fx-font-size: 26; -fx-font-weight: bold;" />
                        <Region prefHeight="6" />
                        <Label text="Harap simpan struk digital ini" style="-fx-text-fill: #9CA3AF; -fx-font-size: 10;" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
