<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>

<AnchorPane prefWidth="900" prefHeight="700" style="-fx-background-color: #F9FAFB;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="siptek.kantinemama.controller.pelanggan.PembayaranQRISController">
    <children>
        <VBox alignment="CENTER" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
            <children>
                <VBox alignment="CENTER" spacing="14" prefWidth="420" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 32;">
                    <children>
                        <Label text="Pembayaran QRIS" style="-fx-text-fill: #111827; -fx-font-size: 20; -fx-font-weight: bold;" />
                        <VBox alignment="CENTER" spacing="6" prefWidth="220" prefHeight="220" style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 8; -fx-padding: 10;">
                            <children>
                                <Label text="Scan to Pay" style="-fx-text-fill: #111827; -fx-font-size: 12; -fx-font-weight: bold;" />
                                <ImageView fx:id="imgQrCode" fitWidth="150" fitHeight="150" preserveRatio="false" />
                                <Label text="SECURE PAYMENT" style="-fx-text-fill: #111827; -fx-font-size: 10; -fx-font-weight: bold;" />
                                <Label text="Scan with your smartphone camera" style="-fx-text-fill: #9CA3AF; -fx-font-size: 9;" />
                                <Label text="Total Amount: Rp 74.800" style="-fx-text-fill: #111827; -fx-font-size: 11; -fx-font-weight: bold;" />
                            </children>
                        </VBox>
                        <Label text="Scan QRIS ini menggunakan aplikasi M-Banking atau E-Wallet Anda (Gopay, DANA, BCA, dll)." wrapText="true" textAlignment="CENTER" prefWidth="360" style="-fx-text-fill: #6B7280; -fx-font-size: 13;" />
                        <Label fx:id="lblCountdown" text="⏱  Sisa waktu pembayaran: 14:58" style="-fx-background-color: #FFEBEE; -fx-text-fill: #EF4444; -fx-font-size: 12; -fx-font-weight: bold; -fx-padding: 6 14 6 14; -fx-background-radius: 6;" />
                        <HBox spacing="12">
                            <children>
                                <Button fx:id="btnBatal" text="Batal" onAction="#onBatal" prefWidth="140" prefHeight="44" style="-fx-background-color: #FFFFFF; -fx-text-fill: #374151; -fx-font-size: 14; -fx-font-weight: bold; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" />
                                <Button fx:id="btnCekStatus" text="Cek Status" onAction="#onCekStatus" prefWidth="140" prefHeight="44" style="-fx-background-color: #0F2044; -fx-text-fill: #FFFFFF; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: transparent; -fx-cursor: hand;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
