<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>

<AnchorPane prefWidth="1280" prefHeight="1000" style="-fx-background-color: #F9FAFB;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="siptek.kantinemama.controller.pelanggan.PesananSayaController">
    <children>
        <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="64" minHeight="64" maxHeight="64" spacing="28" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0; -fx-padding: 0 24 0 24;">
                    <children>
                        <Label text="Kantin E Mama" style="-fx-text-fill: #0F2044; -fx-font-size: 18; -fx-font-weight: bold;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="navMenu" text="Menu" onAction="#onNavMenu" style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-font-size: 14; -fx-border-color: transparent; -fx-cursor: hand;" />
                        <Button fx:id="navOrders" text="Pesanan Saya" onAction="#onNavOrders" style="-fx-background-color: transparent; -fx-text-fill: #1565C0; -fx-font-size: 14; -fx-font-weight: bold; -fx-border-color: transparent; -fx-cursor: hand;" />
                        <Button fx:id="navHelp" text="Bantuan" onAction="#onNavHelp" style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-font-size: 14; -fx-border-color: transparent; -fx-cursor: hand;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField promptText="🔍  Cari pesanan..." prefWidth="240" prefHeight="36" style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 12; -fx-prompt-text-fill: #9CA3AF;" />
                        <StackPane>
                            <children>
                                <Button fx:id="navCart" text="🛒" onAction="#onNavCart" style="-fx-background-color: transparent; -fx-text-fill: #111827; -fx-font-size: 16; -fx-border-color: transparent; -fx-cursor: hand;" />
                                <Region prefWidth="8" prefHeight="8" minWidth="8" minHeight="8" maxWidth="8" maxHeight="8" style="-fx-background-color: #EF4444; -fx-background-radius: 4;" StackPane.alignment="TOP_RIGHT" translateX="-2" translateY="2" />
                            </children>
                        </StackPane>
                    </children>
                </HBox>
                <VBox spacing="16" VBox.vgrow="ALWAYS" style="-fx-padding: 24 32 24 32;">
                    <children>
                        <VBox spacing="2">
                            <children>
                                <Label text="Status Pesanan Saya" style="-fx-text-fill: #111827; -fx-font-size: 24; -fx-font-weight: bold;" />
                                <Label text="Pantau pesanan aktif Anda atau tinjau riwayat pembelian lampau." style="-fx-text-fill: #6B7280; -fx-font-size: 13;" />
                            </children>
                        </VBox>
                        <VBox spacing="16" style="-fx-background-color: #FFFFFF; -fx-border-color: #1565C0; -fx-border-width: 0 0 0 4; -fx-padding: 20 24 20 20;">
                            <children>
                                <HBox alignment="TOP_LEFT">
                                    <children>
                                        <VBox spacing="6">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="10">
                                                    <children>
                                                        <Label text="SEDANG DIPROSES" style="-fx-background-color: #DBEAFE; -fx-text-fill: #1565C0; -fx-font-size: 10; -fx-font-weight: bold; -fx-padding: 3 8 3 8; -fx-background-radius: 10;" />
                                                        <Label text="Pesanan Aktif Saat Ini" style="-fx-text-fill: #6B7280; -fx-font-size: 12;" />
                                                    </children>
                                                </HBox>
                                                <Label text="Order ID #ORD-88219" style="-fx-text-fill: #111827; -fx-font-size: 20; -fx-font-weight: bold;" />
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <VBox alignment="TOP_RIGHT" spacing="2">
                                            <children>
                                                <Label text="TOTAL TERBAYAR" style="-fx-text-fill: #9CA3AF; -fx-font-size: 10;" />
                                                <Label text="Rp 74.800" style="-fx-text-fill: #111827; -fx-font-size: 16; -fx-font-weight: bold;" />
                                            </children>
                                        </VBox>
                                        <Region prefWidth="24" />
                                        <VBox alignment="TOP_RIGHT" spacing="2">
                                            <children>
                                                <Label text="LOKASI MEJA" style="-fx-text-fill: #9CA3AF; -fx-font-size: 10;" />
                                                <Label text="MEJA M12" style="-fx-text-fill: #1565C0; -fx-font-size: 16; -fx-font-weight: bold;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER">
                                    <children>
                                        <StackPane maxWidth="34" maxHeight="34" style="-fx-min-width: 34; -fx-min-height: 34; -fx-max-width: 34; -fx-max-height: 34; -fx-background-color: #1565C0; -fx-background-radius: 17;">
                                            <children>
                                                <Label text="✓" style="-fx-text-fill: #FFFFFF; -fx-font-size: 14; -fx-font-weight: bold;" />
                                            </children>
                                        </StackPane>
                                        <Region prefHeight="3" minHeight="3" maxHeight="3" HBox.hgrow="ALWAYS" style="-fx-background-color: #1565C0;" />
                                        <StackPane maxWidth="34" maxHeight="34" style="-fx-min-width: 34; -fx-min-height: 34; -fx-max-width: 34; -fx-max-height: 34; -fx-background-color: #1565C0; -fx-background-radius: 17;">
                                            <children>
                                                <Label text="🍴" style="-fx-text-fill: #FFFFFF; -fx-font-size: 14;" />
                                            </children>
                                        </StackPane>
                                        <Region prefHeight="3" minHeight="3" maxHeight="3" HBox.hgrow="ALWAYS" style="-fx-background-color: #E5E7EB;" />
                                        <StackPane maxWidth="34" maxHeight="34" style="-fx-min-width: 34; -fx-min-height: 34; -fx-max-width: 34; -fx-max-height: 34; -fx-background-color: #E5E7EB; -fx-background-radius: 17;">
                                            <children>
                                                <Label text="✓" style="-fx-text-fill: #9CA3AF; -fx-font-size: 14; -fx-font-weight: bold;" />
                                            </children>
                                        </StackPane>
                                    </children>
                                </HBox>
                                <HBox>
                                    <children>
                                        <Label text="Diterima / Lunas" style="-fx-text-fill: #1565C0; -fx-font-size: 11; -fx-font-weight: bold;" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label text="Sedang Dimasak" style="-fx-text-fill: #1565C0; -fx-font-size: 11; -fx-font-weight: bold;" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label text="Selesai" style="-fx-text-fill: #9CA3AF; -fx-font-size: 11;" />
                                    </children>
                                </HBox>
                                <Region prefHeight="1" minHeight="1" maxHeight="1" style="-fx-background-color: #E5E7EB;" />
                                <HBox alignment="CENTER_LEFT" spacing="30">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <children>
                                                <Label text="⏱" style="-fx-text-fill: #1565C0; -fx-font-size: 15;" />
                                                <VBox spacing="1">
                                                    <children>
                                                        <Label text="Estimasi Waktu" style="-fx-text-fill: #111827; -fx-font-size: 12; -fx-font-weight: bold;" />
                                                        <Label text="8 - 12 Menit Tersisa" style="-fx-text-fill: #6B7280; -fx-font-size: 11;" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <children>
                                                <Label text="📋" style="-fx-text-fill: #1565C0; -fx-font-size: 15;" />
                                                <VBox spacing="1">
                                                    <children>
                                                        <Label text="Detail Menu" style="-fx-text-fill: #111827; -fx-font-size: 12; -fx-font-weight: bold;" />
                                                        <Label text="2x Sate Ayam Madura, 2x Es Teh Manis" style="-fx-text-fill: #6B7280; -fx-font-size: 11;" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button fx:id="btnHubungiKantin" text="💬  Hubungi Kantin" onAction="#onHubungiKantin" prefHeight="40" style="-fx-background-color: #0F2044; -fx-text-fill: #FFFFFF; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: transparent; -fx-cursor: hand;" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <VBox spacing="12" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 18;">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Riwayat Pesanan Lampau" style="-fx-text-fill: #111827; -fx-font-size: 15; -fx-font-weight: bold;" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button fx:id="btnFilter" text="Filter" onAction="#onFilter" prefHeight="34" style="-fx-background-color: #FFFFFF; -fx-text-fill: #374151; -fx-font-size: 12; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" />
                                        <Button fx:id="btnExportPdf" text="Export PDF" onAction="#onExportPdf" prefHeight="34" style="-fx-background-color: #FFFFFF; -fx-text-fill: #374151; -fx-font-size: 12; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" />
                                    </children>
                                </HBox>
                                <TableView fx:id="tblRiwayat" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colTanggal" text="TANGGAL" prefWidth="140" />
                                        <TableColumn fx:id="colIdPesanan" text="ID PESANAN" prefWidth="120" />
                                        <TableColumn fx:id="colItemMakanan" text="ITEM MAKANAN" prefWidth="280" />
                                        <TableColumn fx:id="colTotalPengeluaran" text="TOTAL PENGELUARAN" prefWidth="160" />
                                        <TableColumn fx:id="colStatusPesanan" text="STATUS PESANAN" prefWidth="140" />
                                        <TableColumn fx:id="colStatusPembayaran" text="STATUS PEMBAYARAN" prefWidth="150" />
                                    </columns>
                                </TableView>
                                <Label fx:id="lblFooterInfo" text="Menampilkan 4 dari 42 item" style="-fx-text-fill: #6B7280; -fx-font-size: 12;" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
