                                                </HBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                <Region VBox.vgrow="ALWAYS" />
                                <Region maxHeight="1" minHeight="1" prefHeight="1" style="-fx-background-color: #E5E7EB;" />
                                <VBox spacing="8" style="-fx-padding: 14 20 20 20; -fx-background-color: #F9FAFB;">
                                    <children>
                                        <HBox>
                                            <children>
                                                <Label style="-fx-text-fill: #374151; -fx-font-size: 13;" text="Subtotal" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label style="-fx-text-fill: #374151; -fx-font-size: 13;" text="Rp68.000" />
                                            </children>
                                        </HBox>
                                        <HBox>
                                            <children>
                                                <Label style="-fx-text-fill: #374151; -fx-font-size: 13;" text="Pajak Resto (10%)" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label style="-fx-text-fill: #374151; -fx-font-size: 13;" text="Rp6.800" />
                                            </children>
                                        </HBox>
                                        <Region maxHeight="1" minHeight="1" prefHeight="1" style="-fx-background-color: #D1D5DB;" />
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label style="-fx-text-fill: #111827; -fx-font-size: 16; -fx-font-weight: bold;" text="Total" />
