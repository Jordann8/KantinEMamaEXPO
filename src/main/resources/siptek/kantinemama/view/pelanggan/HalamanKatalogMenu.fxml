                                                <Label fx:id="lblTotal" style="-fx-text-fill: #111827; -fx-font-size: 20; -fx-font-weight: bold;" text="Rp 74.800" />
                                            </children>
                                        </HBox>
                                        <Button fx:id="btnKonfirmasi" maxWidth="1.7976931348623157E308" onAction="#onKonfirmasi" prefHeight="46" style="-fx-background-color: #0F2044; -fx-text-fill: #FFFFFF; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: transparent; -fx-cursor: hand;" text="KONFIRMASI PESANAN  →" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
