                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                        <VBox maxWidth="320" minWidth="320" prefWidth="320" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 0 1;">
