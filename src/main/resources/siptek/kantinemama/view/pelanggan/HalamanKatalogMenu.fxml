                        <Button fx:id="navOrders" onAction="#onNavOrders" style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-font-size: 14; -fx-border-color: transparent; -fx-cursor: hand;" text="Pesanan Saya" />
