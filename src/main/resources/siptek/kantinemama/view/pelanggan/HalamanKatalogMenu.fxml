                                                        <Button fx:id="btnPlus1" onAction="#onPlus1" prefHeight="22" prefWidth="22" style="-fx-background-color: transparent; -fx-text-fill: #111827; -fx-font-size: 13; -fx-border-color: transparent; -fx-cursor: hand;" text="+" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" spacing="10">
                                            <children>
                                                <Region maxHeight="46" maxWidth="46" minHeight="46" minWidth="46" prefHeight="46" prefWidth="46" style="-fx-background-color: #E5E7EB; -fx-background-radius: 6;" />
                                                <VBox spacing="2">
                                                    <children>
                                                        <Label style="-fx-text-fill: #111827; -fx-font-size: 13; -fx-font-weight: bold;" text="Es Teh Manis" />
                                                        <Label style="-fx-text-fill: #374151; -fx-font-size: 12;" text="Rp 8.000" />
                                                        <Label style="-fx-text-fill: #9CA3AF; -fx-font-size: 11;" text="(2x Rp 4.000)" />
                                                    </children>
                                                </VBox>
                                                <Region HBox.hgrow="ALWAYS" />
                                                <HBox alignment="CENTER" spacing="6" style="-fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 6; -fx-padding: 3 6 3 6;">
                                                    <children>
                                                        <Button fx:id="btnMinus2" onAction="#onMinus2" prefHeight="22" prefWidth="22" style="-fx-background-color: transparent; -fx-text-fill: #111827; -fx-font-size: 13; -fx-border-color: transparent; -fx-cursor: hand;" text="-" />
