                </HBox>
                <HBox VBox.vgrow="ALWAYS">
                    <children>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: #F9FAFB; -fx-border-color: transparent;" HBox.hgrow="ALWAYS">
