                                                        <Button fx:id="btnPlus2" onAction="#onPlus2" prefHeight="22" prefWidth="22" style="-fx-background-color: transparent; -fx-text-fill: #111827; -fx-font-size: 13; -fx-border-color: transparent; -fx-cursor: hand;" text="+" />
