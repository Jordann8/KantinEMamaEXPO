<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>

<AnchorPane prefWidth="1280" prefHeight="900" style="-fx-background-color: #F9FAFB;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="siptek.kantinemama.controller.owner.LaporanKeuangan1Controller">
    <children>
        <ScrollPane fitToWidth="true" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" style="-fx-background-color: #F9FAFB; -fx-border-color: transparent;">
            <content>
                <VBox spacing="18" style="-fx-padding: 24 32 32 32;">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <VBox>
                                    <children>
                                        <Label text="Laporan Keuangan" style="-fx-text-fill: #111827; -fx-font-size: 24; -fx-font-weight: bold;" />
                                        <Label fx:id="lblPeriode" text="Periode Operasional: 1 Juni 2026 - 30 Juni 2026" style="-fx-text-fill: #6B7280; -fx-font-size: 12;" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <children>
                                        <Button fx:id="btnEksporExcelPdf" text="🖶  Ekspor PDF" onAction="#onEksporExcelPdf" prefHeight="40" style="-fx-background-color: #0F2044; -fx-text-fill: #FFFFFF; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: transparent; -fx-cursor: hand;" />
                                        <Button fx:id="btnKeluar" text="⏻  KELUAR" onAction="#onKeluar" prefHeight="40" style="-fx-background-color: #EF4444; -fx-text-fill: #FFFFFF; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: transparent; -fx-cursor: hand;" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>
                        <HBox spacing="18">
                            <children>
                                <VBox spacing="8" HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 20;">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label text="TOTAL TUNAI KASIR" style="-fx-text-fill: #6B7280; -fx-font-size: 12; -fx-font-weight: bold;" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label text="💵" style="-fx-text-fill: #374151; -fx-font-size: 15;" />
                                            </children>
                                        </HBox>
                                        <Label fx:id="lblTotalTunai" text="Rp0" style="-fx-text-fill: #111827; -fx-font-size: 30; -fx-font-weight: bold;" />
                                        <Label fx:id="lblTunaiTrend" text="Berdasarkan data transaksi saat ini" style="-fx-text-fill: #1565C0; -fx-font-size: 12;" />
                                    </children>
                                </VBox>
                                <VBox spacing="8" HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 20;">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label text="QRIS" style="-fx-text-fill: #6B7280; -fx-font-size: 12; -fx-font-weight: bold;" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label text="⛶" style="-fx-text-fill: #374151; -fx-font-size: 15;" />
                                            </children>
                                        </HBox>
                                        <Label fx:id="lblTotalQris" text="Rp0" style="-fx-text-fill: #111827; -fx-font-size: 30; -fx-font-weight: bold;" />
                                        <Label fx:id="lblQrisTrend" text="Berdasarkan data transaksi saat ini" style="-fx-text-fill: #1565C0; -fx-font-size: 12;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <VBox style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10;">
                            <children>
                                <HBox alignment="CENTER_LEFT" style="-fx-padding: 16;">
                                    <children>
                                        <Label text="Riwayat" style="-fx-text-fill: #111827; -fx-font-size: 16; -fx-font-weight: bold;" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <children>
                                                <Button fx:id="btnFilter" text="⚌  Filter" onAction="#onFilter" prefHeight="34" style="-fx-background-color: #FFFFFF; -fx-text-fill: #374151; -fx-font-size: 12; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" />
                                                <Button fx:id="btnPilihBulan" text="📅  Juni 2026" onAction="#onPilihBulan" prefHeight="34" style="-fx-background-color: #FFFFFF; -fx-text-fill: #374151; -fx-font-size: 12; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" />
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" style="-fx-background-color: #0F2044; -fx-padding: 12 16 12 16;">
                                    <children>
                                        <Label text="TANGGAL" prefWidth="180" style="-fx-text-fill: #FFFFFF; -fx-font-size: 11; -fx-font-weight: bold;" />
                                        <Label text="METODE BAYAR" prefWidth="170" style="-fx-text-fill: #FFFFFF; -fx-font-size: 11; -fx-font-weight: bold;" />
                                        <Label text="VOLUME" prefWidth="120" style="-fx-text-fill: #FFFFFF; -fx-font-size: 11; -fx-font-weight: bold;" />
                                        <Label text="PENDAPATAN KOTOR" prefWidth="200" style="-fx-text-fill: #FFFFFF; -fx-font-size: 11; -fx-font-weight: bold;" />
                                        <Label text="PENDAPATAN BERSIH" HBox.hgrow="ALWAYS" style="-fx-text-fill: #FFFFFF; -fx-font-size: 11; -fx-font-weight: bold;" />
                                    </children>
                                </HBox>
                                <VBox fx:id="riwayatRows" />
                                <VBox fx:id="emptyStateRiwayat" alignment="CENTER" spacing="8" visible="false" managed="false" style="-fx-padding: 40;">
                                    <children>
                                        <Label text="📋" style="-fx-text-fill: #D1D5DB; -fx-font-size: 26;" />
                                        <Label text="Belum ada transaksi tercatat pada periode ini." style="-fx-text-fill: #9CA3AF; -fx-font-size: 13;" />
                                    </children>
                                </VBox>
                                <Label fx:id="lblFooterInfo" text="Menampilkan 0 hari operasional" style="-fx-text-fill: #6B7280; -fx-font-size: 12; -fx-padding: 12 16 16 16;" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
