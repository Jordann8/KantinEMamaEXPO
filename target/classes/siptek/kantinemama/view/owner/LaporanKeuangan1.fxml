<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900" prefWidth="1280" style="-fx-background-color: #F9FAFB;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="siptek.kantinemama.controller.owner.LaporanKeuangan1Controller">
    <children>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #F9FAFB; -fx-border-color: transparent;" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <content>
                <VBox spacing="18" style="-fx-padding: 24 32 32 32;">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <VBox>
                                    <children>
                                        <Label style="-fx-text-fill: #111827; -fx-font-size: 24; -fx-font-weight: bold;" text="Laporan Keuangan" />
                                        <Label fx:id="lblPeriode" style="-fx-text-fill: #6B7280; -fx-font-size: 12;" text="Periode Operasional: 1 Juni 2026 - 30 Juni 2026" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnEksporExcelPdf" onAction="#onEksporExcelPdf" prefHeight="40" prefWidth="106.0" style="-fx-background-color: #0F2044; -fx-text-fill: #FFFFFF; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: transparent; -fx-cursor: hand;" text="🖶  Ekspor PDF" />
                                <Button fx:id="btnKeluar" onAction="#onKeluar" prefHeight="40" style="-fx-background-color: #EF4444; -fx-text-fill: #FFFFFF; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: transparent; -fx-cursor: hand;" text="⏻  KELUAR">
                           <HBox.margin>
                              <Insets left="10.0" />
                           </HBox.margin></Button>
                            </children>
                        </HBox>
                        <HBox spacing="18">
                            <children>
                                <VBox spacing="8" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label style="-fx-text-fill: #6B7280; -fx-font-size: 12; -fx-font-weight: bold;" text="TOTAL TUNAI KASIR" />
                                                <Region HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                        <Label fx:id="lblTotalTunai" style="-fx-text-fill: #111827; -fx-font-size: 30; -fx-font-weight: bold;" text="Rp0" />
                                        <Label fx:id="lblTunaiTrend" style="-fx-text-fill: #1565C0; -fx-font-size: 12;" text="Berdasarkan data transaksi saat ini" />
                                    </children>
                                </VBox>
                                <VBox spacing="8" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label style="-fx-text-fill: #6B7280; -fx-font-size: 12; -fx-font-weight: bold;" text="QRIS" />
                                                <Region HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                        <Label fx:id="lblTotalQris" style="-fx-text-fill: #111827; -fx-font-size: 30; -fx-font-weight: bold;" text="Rp0" />
                                        <Label fx:id="lblQrisTrend" style="-fx-text-fill: #1565C0; -fx-font-size: 12;" text="Berdasarkan data transaksi saat ini" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <VBox style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10;">
                            <children>
                                <HBox alignment="CENTER_LEFT" style="-fx-padding: 16;">
                                    <children>
                                        <Label style="-fx-text-fill: #111827; -fx-font-size: 16; -fx-font-weight: bold;" text="Riwayat" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button fx:id="btnFilter" onAction="#onFilter" prefHeight="34" style="-fx-background-color: #FFFFFF; -fx-text-fill: #374151; -fx-font-size: 12; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" text="⚌  Filter" />
                                        <Button fx:id="btnPilihBulan" onAction="#onPilihBulan" prefHeight="34" style="-fx-background-color: #FFFFFF; -fx-text-fill: #374151; -fx-font-size: 12; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" text="📅  Juni 2026">
                                 <HBox.margin>
                                    <Insets left="10.0" />
                                 </HBox.margin></Button>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" style="-fx-background-color: #0F2044; -fx-padding: 12 16 12 16;">
                                    <children>
                                        <Label prefWidth="180" style="-fx-text-fill: #FFFFFF; -fx-font-size: 11; -fx-font-weight: bold;" text="TANGGAL" />
                                        <Label prefWidth="170" style="-fx-text-fill: #FFFFFF; -fx-font-size: 11; -fx-font-weight: bold;" text="METODE BAYAR" />
                                        <Label prefWidth="120" style="-fx-text-fill: #FFFFFF; -fx-font-size: 11; -fx-font-weight: bold;" text="VOLUME" />
                                        <Label prefWidth="200" style="-fx-text-fill: #FFFFFF; -fx-font-size: 11; -fx-font-weight: bold;" text="PENDAPATAN KOTOR" />
                                        <Label style="-fx-text-fill: #FFFFFF; -fx-font-size: 11; -fx-font-weight: bold;" text="PENDAPATAN BERSIH" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                                <VBox fx:id="riwayatRows" />
                                <VBox fx:id="emptyStateRiwayat" alignment="CENTER" managed="false" spacing="8" style="-fx-padding: 40;" visible="false">
                                    <children>
                                        <Label style="-fx-text-fill: #D1D5DB; -fx-font-size: 26;" text="📋" />
                                        <Label style="-fx-text-fill: #9CA3AF; -fx-font-size: 13;" text="Belum ada transaksi tercatat pada periode ini." />
                                    </children>
                                </VBox>
                                <Label fx:id="lblFooterInfo" style="-fx-text-fill: #6B7280; -fx-font-size: 12; -fx-padding: 12 16 16 16;" text="Menampilkan 0 hari operasional" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
