<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="520" prefWidth="1024" style="-fx-background-color: #F9FAFB;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="siptek.kantinemama.controller.pelanggan.PembayaranTunaiController">
    <children>
        <HBox alignment="CENTER" spacing="60" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <children>
                <VBox prefWidth="380" spacing="16">
                    <children>
                        <Label style="-fx-text-fill: #111827; -fx-font-size: 24; -fx-font-weight: bold;" text="Pembayaran Tunai" />
                        <Label style="-fx-text-fill: #374151; -fx-font-size: 14;" text="Silakan tunjukkan struk ini atau sebutkan Order ID #ORD-88219 kepada Kasir untuk melakukan pembayaran tunai." wrapText="true" />
                        <Button fx:id="btnKembaliKatalog" onAction="#onKembaliKatalog" prefHeight="42" prefWidth="180" style="-fx-background-color: #E5E7EB; -fx-text-fill: #374151; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-color: transparent; -fx-cursor: hand;" text="Kembali ke Menu" />
                    </children>
               <HBox.margin>
                  <Insets top="200.0" />
               </HBox.margin>
                </VBox>
                <VBox alignment="CENTER" prefWidth="340" spacing="6" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20;">
                    <children>
                        <Label style="-fx-text-fill: #0F2044; -fx-font-size: 16; -fx-font-weight: bold;" text="Kantin E Mama" />
                        <Label style="-fx-text-fill: #6B7280; -fx-font-size: 10;" text="TRANS ID: #ORD-88219" />
                        <Label style="-fx-text-fill: #6B7280; -fx-font-size: 10;" text="14 Juli 2026 - 12:45" />
                        <Region prefHeight="10" />
                        <Region maxHeight="1" minHeight="1" prefHeight="1" prefWidth="290" style="-fx-background-color: #D1D5DB;" />
                        <HBox prefWidth="290">
                            <children>
                                <Label style="-fx-text-fill: #111827; -fx-font-size: 12;" text="2x Sate Ayam Madura" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label style="-fx-text-fill: #111827; -fx-font-size: 12;" text="60.000" />
                            </children>
                        </HBox>
                        <HBox prefWidth="290">
                            <children>
                                <Label style="-fx-text-fill: #111827; -fx-font-size: 12;" text="2x Es Teh Manis" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label style="-fx-text-fill: #111827; -fx-font-size: 12;" text="8.000" />
                            </children>
                        </HBox>
                        <Region maxHeight="1" minHeight="1" prefHeight="1" prefWidth="290" style="-fx-background-color: #D1D5DB;" />
                        <HBox prefWidth="290">
                            <children>
                                <Label style="-fx-text-fill: #374151; -fx-font-size: 12;" text="Subtotal" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label style="-fx-text-fill: #374151; -fx-font-size: 12;" text="68.000" />
                            </children>
                        </HBox>
                        <HBox prefWidth="290">
                            <children>
                                <Label style="-fx-text-fill: #374151; -fx-font-size: 12;" text="Tax (10%)" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label style="-fx-text-fill: #374151; -fx-font-size: 12;" text="6.800" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" prefWidth="290">
                            <children>
                                <Label style="-fx-text-fill: #111827; -fx-font-size: 15; -fx-font-weight: bold;" text="TOTAL" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="lblTotal" style="-fx-text-fill: #111827; -fx-font-size: 17; -fx-font-weight: bold;" text="74.800" />
                            </children>
                        </HBox>
                        <Label rotate="-20" style="-fx-text-fill: #FFEBEE; -fx-font-size: 26; -fx-font-weight: bold;" text="BELUM DIBAYAR" />
                        <Region prefHeight="6" />
                        <Label style="-fx-text-fill: #9CA3AF; -fx-font-size: 10;" text="Harap simpan struk digital ini" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
